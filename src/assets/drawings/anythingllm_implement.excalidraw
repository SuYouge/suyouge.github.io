		{
			"type": "text",
			"id": "9YRlvEHz",
			"x": -362.8947216106741,
			"y": -146.90588775437737,
			"width": 310.546875,
			"height": 276,
			"text": "// 聊天端点\nrouter.post('/chat', async (req, res) => {\n  const { message, workspaceId } = req.body;\n  const workspace = await Workspace.get(workspaceId);\n  \n  // 1. 检索相关文档\n  const context = await VectorDb.similarityResponse(\n    workspace,\n    message\n  );\n  \n  // 2. 调用 LLM\n  const llm = getLLMProvider();\n  const response = await llm.sendChat(\n    formatPrompt(context, message)\n  );\n  \n  // 3. 流式返回\n  res.writeHead(200, {\n    'Content-Type': 'text/event-stream'\n  });\n  response.pipe(res);\n});",
			"fontSize": 10,
			"fontFamily": 3,
			"textAlign": "left",
			"verticalAlign": "top",
			"strokeColor": "#22c55e",
			"fillColor": "transparent",
			"roughness": 0,
			"opacity": 100,
			"containerId": null,
			"originalText": "// 聊天端点\nrouter.post('/chat', async (req, res) => {\n  const { message, workspaceId } = req.body;\n  const workspace = await Workspace.get(workspaceId);\n  \n  // 1. 检索相关文档\n  const context = await VectorDb.similarityResponse(\n    workspace,\n    message\n  );\n  \n  // 2. 调用 LLM\n  const llm = getLLMProvider();\n  const response = await llm.sendChat(\n    formatPrompt(context, message)\n  );\n  \n  // 3. 流式返回\n  res.writeHead(200, {\n    'Content-Type': 'text/event-stream'\n  });\n  response.pipe(res);\n});",
			"autoResize": true,
			"lineHeight": 1.2,
			"version": 102,
			"versionNonce": 650608368,
			"index": "a3",
			"isDeleted": false,
			"fillStyle": "solid",
